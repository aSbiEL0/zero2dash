+    bottom_left = taps["bottom_left"]
+    bottom_right = taps["bottom_right"]
+
+    no_swap_score = abs(((top_right[0] + bottom_right[0]) / 2) - ((top_left[0] + bottom_left[0]) / 2)) + abs(
