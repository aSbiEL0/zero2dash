[Unit]
Description=Refresh Bee Network tram alerts cache
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/pihole/zero2dash
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/home/pihole/zero2dash/.env
ExecStart=/usr/bin/python3 -u /home/pihole/zero2dash/modules/trams/tram_alerts_refresh.py
